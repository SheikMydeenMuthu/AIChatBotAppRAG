<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:AIChatBotAppRAG.Views"
       x:Class="AIChatBotAppRAG.AppShell"
       Shell.FlyoutBehavior="Disabled">
       
    <Tab Title="Chat" Icon="ic_chat.png">
        <ShellContent ContentTemplate="{DataTemplate views:ChatPage}" />
    </Tab>

    <Tab Title="Settings" Icon="ic_settings.png">
        <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" />
    </Tab>

</Shell>
