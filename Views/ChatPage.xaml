<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AIChatBotAppRAG.Views.ChatPage"
             Title="AI Chat Bot">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header with Hamburger Menu -->
        <HorizontalStackLayout Grid.Row="0" BackgroundColor="Blue" Padding="10">
            <Button Text="☰" Command="{Binding ShowConversationsCommand}" 
                    TextColor="White" BackgroundColor="Transparent" FontSize="20"/>
            <Label Text="AI Chat Bot" TextColor="White" FontSize="20" 
                   VerticalOptions="Center"/>
        </HorizontalStackLayout>
        
        <!-- Chat Messages -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="10" Spacing="5">
                <CollectionView ItemsSource="{Binding Messages}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{Binding IsUser, Converter={StaticResource BoolToColorConverter}}" 
                                    HorizontalOptions="{Binding IsUser, Converter={StaticResource AlignmentConverter}}"
                                    Margin="5">
                                <Label Text="{Binding Content}" TextColor="Black" Padding="10"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Message Input -->
        <Grid Grid.Row="2" Padding="10" ColumnDefinitions="*,Auto">
            <Entry Text="{Binding MessageText}" Placeholder="Type a message..." />
            <Button Grid.Column="1" HorizontalOptions="End"
                 Text="Send" Command="{Binding SendMessageCommand}" 
                    BackgroundColor="Blue" TextColor="White"/>
        </Grid>
        
        <!-- Conversation Popup -->
        <Border Grid.Row="1" Grid.RowSpan="2" 
               IsVisible="{Binding IsConversationPopupVisible}"
               BackgroundColor="White"
               HorizontalOptions="Start"
               VerticalOptions="Fill"
               Padding="10">
            <VerticalStackLayout Spacing="10">
                <Label Text="Conversations" FontSize="20" FontAttributes="Bold"/>
                <Button Text="New Chat" Command="{Binding StartNewConversationCommand}" 
                        BackgroundColor="Green" TextColor="White"/>
                <CollectionView ItemsSource="{Binding Conversations}" HeightRequest="400">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Text="{Binding Title}" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectConversationCommand}" 
                                            CommandParameter="{Binding .}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Button Grid.Column="1" Text="🗑" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteConversationCommand}" 
                                        CommandParameter="{Binding .}" 
                                        BackgroundColor="Red" TextColor="White"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="Close" Command="{Binding HideConversationsCommand}" 
                        BackgroundColor="Gray" TextColor="White"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
